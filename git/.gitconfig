[user]
    name = Metin Yalcinkaya
    email = metinyalcinkaya@hotmail.com.au
    signingkey = ~/.ssh/id_ed25519.pub
[core]
    editor = nvim
[init]
    defaultBranch = main
[status]
    branch = true
    showStash = true
[gpg]
   format = ssh
[gpg "ssh"]
    program = "/opt/1Password/op-ssh-sign"
    allowedSignersFile = ~/.config/git/allowed_signers
[commit]
    gpgsign = true
[push]
    autoSetupRemote = true
